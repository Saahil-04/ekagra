<?xml version="1.0" encoding="utf-8"?>
<!--
  item_onboard_welcome.xml — Slide 1: First impression
  Full-screen gradient background, app name, tagline, "Get Started" button.
  Elements are animated in by the adapter (start hidden, stagger-reveal).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboard_gradient">

    <!-- Content block centred slightly above middle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <!-- Shield / logo mark -->
        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="fitCenter"
            android:padding="6dp"
            app:tint="#FFFFFF"
            android:alpha="0.95"
            android:layout_marginBottom="28dp"
            android:contentDescription="@null" />

        <!-- App name -->
        <TextView
            android:id="@+id/tvWelcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="38sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="14dp" />

        <!-- Tagline -->
        <TextView
            android:id="@+id/tvWelcomeTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_welcome_tagline"
            android:textSize="17sp"
            android:lineSpacingMultiplier="1.5"
            android:textColor="#DDFFFFFF"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <!-- Get Started CTA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGetStarted"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="@string/onboard_welcome_cta"
            android:textSize="16sp"
            android:textColor="?attr/colorPrimary"
            android:paddingHorizontal="36dp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="26dp"
            app:elevation="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
