<?xml version="1.0" encoding="utf-8"?>
<!--
  item_onboard_done.xml — Slide 4: Completion / Reinforcement
  "You're now in control" message with a prominent "Let's Start" CTA.
  Full-screen gradient (same family as welcome, slightly darker).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_onboard_gradient_done">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.42">

        <!-- Big check / celebration mark -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="72sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Primary message -->
        <TextView
            android:id="@+id/tvDoneTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_done_title"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="16dp" />

        <!-- Secondary message -->
        <TextView
            android:id="@+id/tvDoneSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_done_sub"
            android:textSize="16sp"
            android:textColor="#DDFFFFFF"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="52dp" />

        <!-- Let's Start CTA -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLetsStart"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/onboard_done_cta"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:paddingHorizontal="48dp"
            app:backgroundTint="#FFFFFF"
            app:cornerRadius="28dp"
            app:elevation="0dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
