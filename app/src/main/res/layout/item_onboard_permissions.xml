<?xml version="1.0" encoding="utf-8"?>
<!--
  item_onboard_permissions.xml — Slide 3: Critical permissions
  Three permission rows (Accessibility, Overlay, Battery), each with
  a live ✔/✖ status and a button to open the relevant system screen.
  The "Next" button is disabled until all three are granted.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:clipToPadding="false"
    android:paddingBottom="80dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingHorizontal="28dp"
        android:paddingTop="60dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_perm_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="-0.015"
            android:textColor="?attr/colorOnBackground"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboard_perm_subtitle"
            android:textSize="14sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="32dp" />

        <!-- ── PERMISSION ROW 1: Accessibility Service ─────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/rowPermA11y"
            style="@style/Widget.Ekagra.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_step_icon_pending"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/settings_24"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboard_perm_a11y_label"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tvPermA11yStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"
                            android:text="✖  Not granted"
                            android:textColor="@color/status_error" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_perm_a11y_desc"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="60dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantA11y"
                    style="@style/Widget.Ekagra.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_perm_open_settings"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="60dp"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PERMISSION ROW 2: Draw over other apps ──────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/rowPermOverlay"
            style="@style/Widget.Ekagra.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_step_icon_pending"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/edit"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboard_perm_overlay_label"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tvPermOverlayStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"
                            android:text="✖  Not granted"
                            android:textColor="@color/status_error" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_perm_overlay_desc"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="60dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantOverlay"
                    style="@style/Widget.Ekagra.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_perm_open_settings"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="60dp"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PERMISSION ROW 3: Battery optimization ──────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/rowPermBattery"
            style="@style/Widget.Ekagra.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_step_icon_pending"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/battery_charging_full"
                            app:tint="?attr/colorPrimary"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/onboard_perm_battery_label"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface" />

                        <TextView
                            android:id="@+id/tvPermBatteryStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"
                            android:text="✖  Not granted"
                            android:textColor="@color/status_error" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_perm_battery_desc"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="60dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantBattery"
                    style="@style/Widget.Ekagra.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/onboard_perm_open_settings"
                    android:textSize="13sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginStart="60dp"
                    app:cornerRadius="10dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Next (disabled until all granted) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPermNext"
            style="@style/Widget.Ekagra.Button"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="@string/onboard_next"
            android:textSize="15sp"
            android:paddingHorizontal="40dp"
            android:enabled="false"
            android:alpha="0.45"
            app:cornerRadius="26dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
