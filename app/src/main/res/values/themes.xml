<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Ekagra" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>

        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>

        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>

        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>


        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>

        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOutlineVariant">@color/md_theme_light_outlineVariant</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowBackground">@color/md_theme_light_background</item>

        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Ekagra.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Ekagra.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Ekagra.Large</item>

        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Ekagra.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.Ekagra.DisplayMedium</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Ekagra.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Ekagra.TitleMedium</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Ekagra.BodyMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Ekagra.LabelSmall</item>

        <item name="materialSwitchStyle">@style/Widget.Ekagra.Switch</item>
        <item name="materialButtonStyle">@style/Widget.Ekagra.Button</item>
        <item name="borderlessButtonStyle">@style/Widget.Ekagra.Button.TextButton</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Ekagra.Button.Outlined</item>

        <item name="android:windowActivityTransitions">true</item>
    </style>

    <!-- ═══ SHAPE APPEARANCES ═══ -->
    <style name="ShapeAppearance.Ekagra.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

    <style name="ShapeAppearance.Ekagra.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Ekagra.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ═══ TYPOGRAPHY ═══ -->
    <style name="TextAppearance.Ekagra.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">36sp</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Ekagra.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">28sp</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Ekagra.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">20sp</item>
        <item name="android:letterSpacing">-0.005</item>
    </style>

    <style name="TextAppearance.Ekagra.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Ekagra.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.5</item>
    </style>

    <style name="TextAppearance.Ekagra.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ═══ WIDGET OVERRIDES ═══ -->
    <style name="Widget.Ekagra.Switch" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="useMaterialThemeColors">true</item>
    </style>

    <style name="Widget.Ekagra.Button" parent="Widget.Material3.Button">
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Ekagra.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Ekagra.Button.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.Ekagra.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Ekagra.Card.Filled" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <!-- ═══ COOLDOWN OVERLAY THEME (unchanged) ═══ -->
    <style name="Theme.Ekagra.Cooldown" parent="Theme.Ekagra">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">?attr/colorSurface</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@style/Animation.Ekagra.Cooldown</item>
    </style>

    <style name="Animation.Ekagra.Cooldown" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_in</item>
    </style>

    <!-- ═══ ONBOARDING THEME (NEW) ═══ -->
    <!--
        Full-screen, edge-to-edge, transparent system bars.
        The gradient slide backgrounds handle visual chrome directly.
    -->
    <style name="Theme.Ekagra.Onboarding" parent="Theme.Ekagra">
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowAnimationStyle">@style/Animation.Ekagra.Onboarding</item>
    </style>

    <style name="Animation.Ekagra.Onboarding" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/fade_in</item>
    </style>

</resources>
